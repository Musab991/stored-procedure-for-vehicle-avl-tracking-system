DECLARE @TodayDate       DATE = @FromDate;
DECLARE @TodayDayOfMonth   INT          = DATEPART(DAY, @TodayDate);
DECLARE @TodayIdx          INT          = DATEPART(WEEKDAY, @TodayDate) - 1; -- 0..6
DECLARE @TripCount INT
DECLARE @TenantId UNIQUEIDENTIFIER='10000001-1001-1001-1001-100000000001'
-- Clean up temp tables if they already exist
SELECT @TripCount =COUNT(1) FROM dbo.Trips 
INSERT INTO #OperationalPlans (
    Id,
    ReferenceCode,
    DisposalPointId,
    WaterSourceId,
    OvernightPointId,
    ContractId,
    Status,
    PlanCoverage,
    IsDeleted,
    CreatedDate,
    CreatedBy,
    ModifiedDate,
    ModifiedBy,
    TenantId,
    EndDate,
    StartDate,
    ContractServiceId,
    TotalTripsCompletionPercentaion,
    TripDurationHours,
    ExpectedCoverage,
    CountActiveTrip,
    SupervisorId,
    ContractingCompanyId,
    MonthlyDays,
    IsMonthly
)
SELECT
    P.Id,
    P.ReferenceCode,
    P.DisposalPointId,
    P.WaterSourceId,
    P.OvernightPointId,
    P.ContractId,
    P.Status,
    P.PlanCoverage,
    P.IsDeleted,
    P.CreatedDate,
    P.CreatedBy,
    P.ModifiedDate,
    P.ModifiedBy,
    P.TenantId,
    P.EndDate,
    P.StartDate,
    P.ContractServiceId,
    P.TotalTripsCompletionPercentaion,
    P.TripDurationHours, 
	P.ExpectedCoverage,
    P.CountActiveTrip,
    P.SupervisorId,
    P.ContractingCompanyId,
    P.MonthlyDays,
    P.IsMonthly
FROM dbo.OperationalPlans P 
INNER JOIN dbo.ContractDetails C ON C.ContractServiceId =P.ContractServiceId
INNER JOIN (SELECT COUNT(1) ServiceCount,OperationalPlanId FROM dbo.OperationalPlanDetails GROUP BY OperationalPlanId) D ON D.OperationalPlanId = P.Id
WHERE
    -- x.CreatedDate <= currentDate
    CAST (P.CreatedDate AS DATE ) <= @TodayDate
    AND
    -- first Where: (weekdays.Any(w.Day == today) OR IsMonthly)
    (
        EXISTS (
            SELECT 1
            FROM dbo.OperationalPlansDay opd
            JOIN dbo.WeekDays wd ON wd.Id = opd.WeekDaysId
            WHERE opd.OperationalPlansId = P.Id
              AND wd.[Day] = @TodayIdx
        )
        OR P.IsMonthly = 1
    )
    AND
    -- second Where:
    -- (IsMonthly && MonthlyDays contains today day-of-month) OR weekdays not empty
    (
        (
            P.IsMonthly = 1
            AND P.MonthlyDays IS NOT NULL
            AND EXISTS (
                SELECT 1
                FROM STRING_SPLIT(P.MonthlyDays, ',') s
            )
        )
        OR EXISTS (
            SELECT 1
            FROM dbo.OperationalPlansDay opd2
            WHERE opd2.OperationalPlansId = P.Id
        )
    )
    -- x.OperationalPlanDetails.IsNotNullOrEmpty()
    AND EXISTS (
        SELECT 1
        FROM dbo.OperationalPlanDetails opd3
        WHERE opd3.OperationalPlanId = P.Id
    )
    AND P.IsDeleted = 0 OPTION (MAXDOP 1);

;WITH ValidDays AS
(
    SELECT
        opd.OperationalPlansId AS PlanId,
        wd.[Day] AS DayIdx
    FROM dbo.OperationalPlansDay opd
    JOIN dbo.WeekDays wd ON wd.Id = opd.WeekDaysId
    WHERE opd.OperationalPlansId IN (
        SELECT Id FROM #OperationalPlans WHERE IsMonthly = 0
    )
    AND opd.IsDeleted = 0
),
OffsetsCTE AS
(
    SELECT
        PlanId,
        ((DayIdx - @TodayIdx + 7) % 7) AS OffsetDays
    FROM ValidDays
),
RankedOffsets AS
(
    SELECT
        o.PlanId,
        o.OffsetDays,
        ROW_NUMBER() OVER (
            PARTITION BY o.PlanId
            ORDER BY
                CASE
                    WHEN o.OffsetDays = 0 THEN 0   -- today first
                    ELSE 1
                END,
                o.OffsetDays                      -- closest future
        ) AS rn
    FROM OffsetsCTE o
)
INSERT INTO #StartTrips (PlanId, StartDate)
SELECT
    p.Id,
    DATEADD(
        SECOND, DATEPART(SECOND, p.StartDate),
        DATEADD(
            MINUTE, DATEPART(MINUTE, p.StartDate),
            DATEADD(
                HOUR, DATEPART(HOUR, p.StartDate),
                DATEADD(
                    DAY, r.OffsetDays,
                    CAST(@TodayDate AS DATETIME2(0))
                )
            )
        )
    )
FROM #OperationalPlans p
JOIN RankedOffsets r ON r.PlanId = p.Id
WHERE p.IsMonthly = 0
AND (
        -- today only if not passed
        (r.OffsetDays = 0 
		AND CAST(p.StartDate AS TIME) >= CAST(GETDATE() AS TIME)
		)
     OR
        -- future always allowed
        (r.OffsetDays > 0)
)
AND r.rn <= 2 OPTION (MAXDOP 1);

INSERT INTO #StartTrips (PlanId, StartDate)
SELECT
    p.Id,
    DATEADD(SECOND, DATEPART(SECOND, p.StartDate),
    DATEADD(MINUTE, DATEPART(MINUTE, p.StartDate),
    DATEADD(HOUR,   DATEPART(HOUR,   p.StartDate),
        CAST(DATEFROMPARTS(YEAR(@TodayDate), MONTH(@TodayDate), CAST(s.value AS INT)) AS DATETIME2(0))
    )))
FROM #OperationalPlans p
CROSS APPLY STRING_SPLIT(p.MonthlyDays, ',') s
WHERE p.IsMonthly = 1
  AND CAST(s.value AS INT) >= @TodayDayOfMonth  OPTION (MAXDOP 1);


